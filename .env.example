# Application
NEXT_PUBLIC_APP_DOMAIN=leads-generator.ai-client-recovery.com
NEXT_PUBLIC_APP_BASE=https://leads-generator.ai-client-recovery.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# AI & LLM
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
GOOGLE_EMAIL_USER=your@gmail.com
GOOGLE_EMAIL_PASS=your-app-password

# Multi-Channel Outreach (Twilio)
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Google Places API (Lead Discovery)
GOOGLE_PLACES_API_KEY=<google-places-api-key>

# LinkedIn Scraper (Hunter.io for email finding)
HUNTER_API_KEY=<hunter-io-api-key>

# Webhooks
TYPEFORM_WEBHOOK_SECRET=<typeform-signing-secret>
JOTFORM_FIELD_NAME=q3_fullName
JOTFORM_FIELD_EMAIL=q4_email
JOTFORM_FIELD_PHONE=q5_phone
JOTFORM_FIELD_BUSINESS_TYPE=q6_businessType
JOTFORM_FIELD_CITY=q7_city

# Lead Capture Page
NEXT_PUBLIC_CAPTURE_OWNER_EMAIL=admin@leads-generator.com
NEXT_PUBLIC_CAPTURE_HEADLINE=Grow Your Business with AI-Powered Outreach
NEXT_PUBLIC_CAPTURE_DESCRIPTION=Get a free consultation on how to attract more clients using smart automation.
NEXT_PUBLIC_CAPTURE_OG_IMAGE=

# Yelp Fusion API (Local Business Discovery)
YELP_API_KEY=<yelp-api-key>

# Job Board (Adzuna API — free tier available)
ADZUNA_APP_ID=<adzuna-app-id>
ADZUNA_APP_KEY=<adzuna-app-key>

# Facebook Lead Ads webhook
FB_VERIFY_TOKEN=<random-string-for-webhook-verification>
FB_APP_SECRET=<facebook-app-secret>
FB_PAGE_ACCESS_TOKEN=<facebook-page-access-token>

# Google Ads Lead Form webhook
GOOGLE_ADS_WEBHOOK_KEY=<google-ads-webhook-key>

# Calendly webhook
CALENDLY_WEBHOOK_SECRET=<calendly-webhook-signing-secret>

# Stripe (paying customers as leads)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Deliverability Verification (ZeroBounce — free tier: 100/mo)
ZEROBOUNCE_API_KEY=<zerobounce-api-key>

# Product Hunt API (Discover new startups)
PRODUCTHUNT_API_TOKEN=<producthunt-developer-token>

# Funding and PR sources
CRUNCHBASE_API_KEY=<crunchbase-api-key>
GNEWS_API_KEY=<gnews-api-key>
WHOISXML_API_KEY=<whoisxml-api-key>

# Inbound automation webhooks
ZAPIER_WEBHOOK_SECRET=<zapier-webhook-secret>
MAKE_WEBHOOK_SECRET=<make-webhook-secret>

# ===== CRM OAUTH INTEGRATIONS =====
# Pipedrive OAuth (get from https://app.pipedrive.com/settings/oauth)
PIPEDRIVE_CLIENT_ID=<pipedrive-oauth-client-id>
PIPEDRIVE_CLIENT_SECRET=<pipedrive-oauth-client-secret>

# HubSpot OAuth (get from https://app.hubspot.com/l/app-marketplace)
HUBSPOT_CLIENT_ID=<hubspot-oauth-app-id>
HUBSPOT_CLIENT_SECRET=<hubspot-oauth-app-secret>

# Salesforce OAuth (get from https://login.salesforce.com)
SALESFORCE_CLIENT_ID=<salesforce-connected-app-client-id>
SALESFORCE_CLIENT_SECRET=<salesforce-connected-app-secret>
SALESFORCE_INSTANCE_URL=https://login.salesforce.com


# Chat Widget
CHAT_WIDGET_OWNER_EMAIL=admin@leads-generator.com
CHAT_WIDGET_ALLOWED_ORIGINS=https://leads-generator.ai-client-recovery.com
CHAT_WIDGET_SYSTEM_PROMPT=You are a friendly sales assistant. Help website visitors and collect their contact info when appropriate.

# Misc
CRON_SECRET=<long-random-string-for-scheduler>
PORT=3400

